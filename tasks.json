[
  {
    "label": "qmake (Debug)",
    "command": "QT_SELECT=qt6 qmake",
    "args": ["-spec linux-g++", "CONFIG+=debug", "CONFIG+=qml_debug"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always",
    "save": "all",
  },
  {
    "label": "build (Debug)",
    "command": ".zed/build.sh",
    "args": ["-d"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "tags": ["bash-script"],
    "save": "all",
  },
  {
    "label": "clean build (Debug)",
    "command": ".zed/build.sh",
    "args": ["-d", "-c"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "tags": ["bash-script"],
    "save": "all",
  },
  {
    "label": "reload (Debug)",
    "command": "mkdir -p $DEBUG_BUILD_DIR && cd $DEBUG_BUILD_DIR && QT_SELECT=qt6 qmake .. -spec linux-g++ CONFIG+=debug CONFIG+=qml_debug && make clean -j$(nproc) && bear -- make -j$(nproc) &&  mv ./compile_commands.json $ZED_WORKTREE_ROOT/",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "run (Debug)",
    "command": "$DEBUG_BUILD_DIR/$EXECUTABLE_NAME",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "build & run (Debug)",
    "command": ".zed/build.sh \"-d\" && $DEBUG_BUILD_DIR/$EXECUTABLE_NAME",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "build (Release)",
    "command": ".zed/build.sh",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "tags": ["bash-script"],
    "save": "all",
  },
  {
    "label": "run (Release)",
    "command": "$RELEASE_BUILD_DIR/$EXECUTABLE_NAME",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "build & run (Release)",
    "command": ".zed/build.sh && $RELEASE_BUILD_DIR/$EXECUTABLE_NAME",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
    "save": "all",
  },
]

