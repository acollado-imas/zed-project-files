[
  {
    "label": "generate compileDB",
    "command": "pio run -t compiledb",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
  },
  {
    "label": "build",
    "command": "pio run",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
  },  
  {
    "label": "build & upload",
    "command": "pio run -t upload",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success",
  },
]{
  "lsp": {
    "clangd": {
      "binary": {
        "path": "clangd",
        "arguments": [
          "--background-index",
          "--clang-tidy",
          "--completion-style=detailed",
          "--header-insertion=never",
          "--log=error",
          "--query-driver=**/*esp32doit-devkit-v1*",
        ],
      },
      "initialization_options": {
        "fallbackFlags": ["-std=gnu++17"],
      },
    },
  },
}
